  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
